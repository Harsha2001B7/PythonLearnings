# =============================================================================
# CarRental — .gitignore
# =============================================================================

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
venv/
.venv/
env/
ENV/
*.pyo
*.pyd
.Python

# ── Environment & Secrets (NEVER commit these) ────────────────────────────────
.env
.env.local
.env.*.local
# Allow .env.example and .env.development/.env.production (no secrets, just keys)
# If those files contain secrets, add them below:
# .env.development
# .env.production

# ── Node / Frontend ───────────────────────────────────────────────────────────
node_modules/
dist/
.next/
out/
.nuxt/
.cache/
*.local
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.npm
.yarn/cache
.yarn/unplugged
.pnp.*

# ── Build artifacts ───────────────────────────────────────────────────────────
apps/web/dist/

# ── Database ──────────────────────────────────────────────────────────────────
apps/data/sqlite/*.db
apps/data/sqlite/*.db-wal
apps/data/sqlite/*.db-shm
*.sqlite
*.sqlite3



# ── IDE & OS ──────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db
desktop.ini


# ── Testing ───────────────────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
.tox/
coverage.xml
*.cover

# ── Logs ─────────────────────────────────────────────────────────────────────
*.log
logs/

# ── Alembic (keep migrations, ignore local-only config overrides) ─────────────
# alembic.ini is committed — do NOT ignore it

# ── Extracted seed data (generated by scripts) ───────────────────────────────
apps/data/seeds/extracted_*.json
*.json
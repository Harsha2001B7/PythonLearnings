# =============================================================================
# Falcon View Car Rentals — Backend Environment Variables
# Copy this file to .env and fill in the values before running.
# NEVER commit the populated .env file to source control.
# =============================================================================

# ── Application ───────────────────────────────────────────────────────────────
PROJECT_NAME=FalconViewCarRentals

# Environment: development | staging | production
ENVIRONMENT=development

# ── URLs ──────────────────────────────────────────────────────────────────────
# The public URL of this backend (used in password reset links, etc.)
BACKEND_URL=http://localhost:8000

# The public URL of the frontend (used in CORS and reset email links)
FRONTEND_URL=http://localhost:5173

# Additional CORS origins (JSON array of strings), e.g.:
# BACKEND_CORS_ORIGINS=["https://your-app.azurestaticapps.net"]
# BACKEND_CORS_ORIGINS=

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite (default, for local dev):
# DATABASE_URI=sqlite:///path/to/falconview.db
#
# Azure PostgreSQL (for production on Azure):
# DATABASE_URI=postgresql+psycopg2://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require

# ── Security ──────────────────────────────────────────────────────────────────
# REQUIRED in production. Generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_IN_PRODUCTION

# JWT token lifetimes
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Google OAuth ──────────────────────────────────────────────────────────────
# Get these from Google Cloud Console → APIs & Services → Credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

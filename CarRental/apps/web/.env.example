# =============================================================================
# Falcon View Car Rentals — Frontend Environment Variables
# Copy this file to .env.local (or .env.development) and fill in the values.
# NEVER commit the populated file to source control.
# =============================================================================

# ── API ───────────────────────────────────────────────────────────────────────
# Backend API base URL (include /api/v1)
# Local:      http://localhost:8000/api/v1
# Production: https://YOUR_APP.azurewebsites.net/api/v1
VITE_API_URL=http://localhost:8000/api/v1

# ── Google OAuth ──────────────────────────────────────────────────────────────
# Get from Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client IDs
# Add the following Authorised JavaScript origins:
#   - http://localhost:5173
#   - https://YOUR_APP.azurestaticapps.net (production)
VITE_GOOGLE_CLIENT_ID=

# ── Contact ───────────────────────────────────────────────────────────────────
# WhatsApp business number (digits only, no + or spaces)
VITE_WHATSAPP_PHONE=971500999733

# Display-formatted contact number
VITE_CONTACT_PHONE=+971 50 099 9733

# ── URLs ──────────────────────────────────────────────────────────────────────
# Override if your frontend is not served from the same domain root
# VITE_FRONTEND_URL=https://YOUR_APP.azurestaticapps.net
